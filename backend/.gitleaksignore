# GitLeaks ignore rules
# WARNING: Keep rules specific. Broad patterns can hide real secrets.

# Environment variable placeholder references (these reference env vars, not hardcoded secrets)
- regex: '\$\{DB_PASSWORD\}'
- regex: '\$\{DB_USERNAME\}'
- regex: '\$\{DB_URL\}'
- regex: '\$\{DB_DRIVER\}'
- regex: '\$\{JWT_SECRET\}'
- regex: '\$\{JWT_EXPIRE\}'
- regex: '\$\{SERVER_PORT\}'
- regex: '\$\{MYSQL_ROOT_PASSWORD\}'
- regex: '\$\{MYSQL_PASSWORD\}'
- regex: '\$\{FRONTEND_PORT\}'
- regex: '\$\{BACKEND_PORT\}'
- regex: '\$\{MOBILE_PORT\}'
- regex: '\$\{MYSQL_PORT\}'
- regex: '\$\{VERSION\}'

# Example files (template values are not production secrets)
- path: \.env\.example$
- path: \.env\.secrets\.example$

# This file itself
- path: \.gitleaksignore$

# Test JWT key (only matches the test-specific line, not real secrets)
- regex: 'test-secret-key-for-jwt-token-generation-256-bit-minimum-length'
