# Copy to .env and adjust for your environment.
# Do not commit real passwords, tokens, or production URLs.

# === MySQL ===
DB_URL=jdbc:mysql://mysql:3306/wisdom_pm?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8
DB_USERNAME=root
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# === Backend ===
# SERVER_PORT=8080               (optional, defaults to 8080)
BACKEND_PORT=8080

# === Frontend ===
FRONTEND_PORT=80

# === Security ===
JWT_SECRET=change-me-to-a-random-string
