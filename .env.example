# ============================================
# 环境变量模板 — 复制为 .env 并修改为你的真实值
#   cp .env.example .env
# ============================================
# WARNING: .env 已加入 .gitignore，切勿提交到版本库

# === MySQL ===
DB_URL=jdbc:mysql://db:3306/property_ms?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8
DB_USERNAME=change-me
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# === Backend ===
# SERVER_PORT=8080
BACKEND_PORT=8080

# === Frontend ===
FRONTEND_PORT=80

# === Mobile ===
# MOBILE_PORT=5174

# === MySQL Port (dev only) ===
# MYSQL_PORT=3307

# === Security ===
# JWT 密钥至少需要 256 bits (32 字符)，推荐 384 bits (48 字符) 以上
# 生成方式: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters
